<?php
/**
 * Copy this file to payment-secrets.php and add your Stripe secret key.
 * Never commit payment-secrets.php to a public repository.
 */
return [
    'stripe_secret_key' => 'sk_test_YOUR_STRIPE_SECRET_KEY',
];
<?php
header('Content-Type: application/json');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: POST, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type');

if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
    http_response_code(204);
    exit;
}

if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
    http_response_code(405);
    echo json_encode(['error' => 'Method not allowed']);
    exit;
}

$secretsFile = __DIR__ . '/payment-secrets.php';
if (!file_exists($secretsFile)) {
    http_response_code(500);
    echo json_encode(['error' => 'Stripe is not configured. Copy api/payment-secrets.example.php to api/payment-secrets.php and add your secret key.']);
    exit;
}

$secrets = require $secretsFile;
$stripeSecret = $secrets['stripe_secret_key'] ?? '';

if (!$stripeSecret || strpos($stripeSecret, 'YOUR_STRIPE') !== false) {
    http_response_code(500);
    echo json_encode(['error' => 'Stripe secret key is missing. Update api/payment-secrets.php.']);
    exit;
}

$payload = json_decode(file_get_contents('php://input'), true);
if (!$payload) {
    http_response_code(400);
    echo json_encode(['error' => 'Invalid request body']);
    exit;
}

$items = $payload['items'] ?? [];
$customer = $payload['customer'] ?? [];
$shipping = floatval($payload['shipping'] ?? 0);
$orderId = $payload['orderId'] ?? ('EP-' . time());

if (empty($items)) {
    http_response_code(400);
    echo json_encode(['error' => 'Cart is empty']);
    exit;
}

$lineItems = [];
$subtotal = 0;

foreach ($items as $item) {
    $qty = max(1, intval($item['quantity'] ?? 1));
    $price = floatval($item['price'] ?? 0);
    if ($price <= 0) {
        http_response_code(400);
        echo json_encode(['error' => 'One or more items are missing a price. Update js/prices.js.']);
        exit;
    }
    $subtotal += $price * $qty;
    $lineItems[] = [
        'price_data' => [
            'currency' => 'usd',
            'product_data' => [
                'name' => $item['display'] ?? ($item['name'] ?? 'Research peptide'),
            ],
            'unit_amount' => intval(round($price * 100)),
        ],
        'quantity' => $qty,
    ];
}

if ($shipping > 0) {
    $lineItems[] = [
        'price_data' => [
            'currency' => 'usd',
            'product_data' => ['name' => 'Shipping'],
            'unit_amount' => intval(round($shipping * 100)),
        ],
        'quantity' => 1,
    ];
}

$scheme = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https' : 'http';
$host = $_SERVER['HTTP_HOST'] ?? 'localhost';
$base = $scheme . '://' . $host;

$sessionData = [
    'mode' => 'payment',
    'success_url' => $base . '/checkout-success.html?order=' . urlencode($orderId) . '&session_id={CHECKOUT_SESSION_ID}',
    'cancel_url' => $base . '/checkout.html?cancelled=1',
    'line_items' => $lineItems,
    'metadata' => [
        'order_id' => $orderId,
        'customer_email' => $customer['email'] ?? '',
    ],
];

if (!empty($customer['email'])) {
    $sessionData['customer_email'] = $customer['email'];
}

$ch = curl_init('https://api.stripe.com/v1/checkout/sessions');
curl_setopt_array($ch, [
    CURLOPT_POST => true,
    CURLOPT_USERPWD => $stripeSecret . ':',
    CURLOPT_POSTFIELDS => http_build_query(flattenStripeParams($sessionData)),
    CURLOPT_RETURNTRANSFER => true,
    CURLOPT_TIMEOUT => 30,
]);

$response = curl_exec($ch);
$httpCode = curl_getinfo($ch, CURLINFO_HTTP_CODE);
curl_close($ch);

$result = json_decode($response, true);

if ($httpCode >= 400 || empty($result['url'])) {
    http_response_code(500);
    echo json_encode([
        'error' => $result['error']['message'] ?? 'Unable to create Stripe checkout session',
    ]);
    exit;
}

echo json_encode(['url' => $result['url']]);

function flattenStripeParams($params, $prefix = '')
{
    $result = [];
    foreach ($params as $key => $value) {
        $k = $prefix === '' ? $key : $prefix . '[' . $key . ']';
        if (is_array($value)) {
            $result = array_merge($result, flattenStripeParams($value, $k));
        } else {
            $result[$k] = $value;
        }
    }
    return $result;
}
