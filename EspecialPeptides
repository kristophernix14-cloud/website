  }

  function formatPrice(amount) {
    return '$' + amount.toFixed(2);
  }

  function getPriceId(card) {
    var key = card.getAttribute('data-product-card');
    if (!key || !window.EPPrices) return null;

    var active = card.querySelector('.size-option.active');
    if (active) {
      var unit = active.getAttribute('data-unit') || 'mg';
      return key + '-' + active.getAttribute('data-size') + unit;
    }

    var fixedBtn = card.querySelector('[data-fixed-size]');
    if (fixedBtn) {
      var fixedUnit = fixedBtn.getAttribute('data-fixed-unit') || 'mg';
      return key + '-' + fixedBtn.getAttribute('data-fixed-size') + fixedUnit;
    }

    return null;
  }

  function ensurePriceMeta(card) {
    var footer = card.querySelector('.product-footer');
    if (!footer) return null;

    var meta = footer.querySelector('.product-footer-meta');
    if (meta) return meta;

    meta = document.createElement('div');
    meta.className = 'product-footer-meta';

    var sizeSpan = footer.querySelector('.product-selected-size');
    var fixedSpan = footer.querySelector('.product-price');

    if (sizeSpan) {
      meta.appendChild(sizeSpan);
    } else if (fixedSpan) {
      meta.appendChild(fixedSpan);
    }

    var priceEl = document.createElement('span');
    priceEl.className = 'product-card-price';
    meta.appendChild(priceEl);

    var addBtn = footer.querySelector('[data-add-cart]');
    footer.insertBefore(meta, addBtn || null);

    return meta;
  }

  function updateCardPrice(card) {
    if (!card) return;
    var meta = ensurePriceMeta(card);
    if (!meta) return;

    var priceEl = meta.querySelector('.product-card-price');
    if (!priceEl) return;

    var id = getPriceId(card);
    var price = id ? window.EPPrices.getPrice(id) : 0;

    if (price > 0) {
      priceEl.textContent = formatPrice(price);
      priceEl.classList.remove('hidden');
    } else {
      priceEl.textContent = '';
      priceEl.classList.add('hidden');
    }
  }

  document.querySelectorAll('[data-product-card]').forEach(function (card) {
    updateCardPrice(card);
  });

  document.querySelectorAll('.size-option').forEach(function (option) {
    option.addEventListener('click', function () {
      var card = option.closest('[data-product-card]');
      if (!card) return;

      card.querySelectorAll('.size-option').forEach(function (opt) {
        opt.classList.remove('active');
        opt.setAttribute('aria-checked', 'false');
