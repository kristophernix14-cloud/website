      window.EPPrices.enrichItem(item);
    }
    var existing = cart.find(function (i) { return i.id === item.id; });
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push(item);
    }
    saveCart();
    renderCart();
    showToast(item.display + ' added to cart');
  }

  function removeFromCart(id) {
    cart = cart.filter(function (i) { return i.id !== id; });
    saveCart();
    renderCart();
  }

