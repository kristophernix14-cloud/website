          '</div>' +
          '<div class="cart-item-controls">' +
            '<button type="button" class="qty-btn" data-qty-delta="-1" data-cart-id="' + item.id + '" aria-label="Decrease quantity">−</button>' +
            '<span class="qty-value">' + item.quantity + '</span>' +
            '<button type="button" class="qty-btn" data-qty-delta="1" data-cart-id="' + item.id + '" aria-label="Increase quantity">+</button>' +
            '<button type="button" class="cart-remove" data-cart-id="' + item.id + '" aria-label="' + escapeHtml(removeLabel) + '">Remove</button>' +
          '</div>' +
        '</div>'
      );
    }).join('');

    itemsEl.querySelectorAll('[data-qty-delta]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        updateQuantity(btn.getAttribute('data-cart-id'), parseInt(btn.getAttribute('data-qty-delta'), 10));
      });
    });

    itemsEl.querySelectorAll('.cart-remove, .cart-item-remove').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-cart-id');
        var removed = cart.find(function (i) { return i.id === id; });
        removeFromCart(id);
        if (removed) showToast((removed.display || removed.name) + ' removed');
      });
    });
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function bindShopLink() {
    var link = document.getElementById('cart-shop-link');
    if (link) {
      link.addEventListener('click', closeCart);
    }
  }

