    showToast._timer = setTimeout(function () {
      toastEl.classList.add('hidden');
    }, 2500);
  }

  function checkout() {
    if (cart.length === 0) {
      showToast('Your cart is empty');
      return;
    }

    cart.forEach(function (item) {
      if (window.EPPrices) window.EPPrices.enrichItem(item);
    });
