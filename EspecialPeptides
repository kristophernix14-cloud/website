      option.setAttribute('aria-checked', 'true');

      var sizeLabel = card.querySelector('.product-selected-size strong');
      var unit = option.getAttribute('data-unit') || 'mg';
      if (sizeLabel) sizeLabel.textContent = option.getAttribute('data-size') + unit;

      updateCardPrice(card);
