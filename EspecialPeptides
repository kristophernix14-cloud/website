    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  }

  function getProductDetails(btn) {
    var card = btn.closest('.product-card');
    if (!card) return null;

    var nameEl = card.querySelector('.product-name');
    var name = nameEl ? nameEl.textContent.trim() : '';
    var productKey = card.getAttribute('data-product-card') || slugify(name);
    var selected = card.querySelector('.size-option.active');
    var fixedSize = btn.getAttribute('data-fixed-size');
    var fixedUnit = btn.getAttribute('data-fixed-unit') || 'mg';
    var size = '';
    var unit = 'mg';
    var display = name;

    if (selected) {
      size = selected.getAttribute('data-size');
      unit = selected.getAttribute('data-unit') || 'mg';
      display = name + ' — ' + size + unit;
    } else if (fixedSize) {
      size = fixedSize;
      unit = fixedUnit;
      display = name + ' — ' + size + unit;
    }

    var id = productKey + (size ? '-' + size + unit : '');

