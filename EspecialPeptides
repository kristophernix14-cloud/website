(function () {
  var container = document.getElementById('dna-helix-3d');
  if (!container) return;

  var PAIRS = 40;
  var RADIUS = 58;
  var STEP_Y = 8;
  var DIAMETER = RADIUS * 2;
  var ANGLE_STEP = 360 / PAIRS;
  var totalHeight = (PAIRS - 1) * STEP_Y;
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  var rotate = document.createElement('div');
  rotate.className = 'dna-rotate';
  if (prefersReducedMotion) {
    rotate.classList.add('dna-rotate--static');
  }

  for (var i = 0; i < PAIRS; i++) {
    var angle = ANGLE_STEP * i;
    var y = i * STEP_Y - totalHeight / 2;

    var rung = document.createElement('div');
    rung.className = 'dna-rung';
    rung.style.transform = 'rotateY(' + angle + 'deg) translateY(' + y + 'px)';

    var nodeA = document.createElement('span');
    nodeA.className = 'dna-node dna-node--a';

    var bond = document.createElement('span');
    bond.className = 'dna-bond';

    var nodeB = document.createElement('span');
    nodeB.className = 'dna-node dna-node--b';

    rung.appendChild(nodeA);
    rung.appendChild(bond);
    rung.appendChild(nodeB);
    rotate.appendChild(rung);

    if (i < PAIRS - 1) {
      var linkA = document.createElement('div');
      linkA.className = 'dna-link dna-link--a';
      linkA.style.transform =
        'rotateY(' + angle + 'deg) translateX(-' + RADIUS + 'px) translateY(' + y + 'px)';

      var rodA = document.createElement('span');
      rodA.className = 'dna-link-rod';
      linkA.appendChild(rodA);
      rotate.appendChild(linkA);

      var linkB = document.createElement('div');
      linkB.className = 'dna-link dna-link--b';
      linkB.style.transform =
        'rotateY(' + angle + 'deg) translateX(' + RADIUS + 'px) translateY(' + y + 'px)';

      var rodB = document.createElement('span');
      rodB.className = 'dna-link-rod';
      linkB.appendChild(rodB);
      rotate.appendChild(linkB);
    }
  }

  var floor = document.createElement('div');
  floor.className = 'dna-floor';
  rotate.appendChild(floor);

  container.appendChild(rotate);

  container.style.setProperty('--dna-radius', RADIUS + 'px');
  container.style.setProperty('--dna-diameter', DIAMETER + 'px');
  container.style.setProperty('--dna-step', STEP_Y + 'px');
})();
(function () {
